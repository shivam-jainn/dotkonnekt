# ─────────────────────────────────────────────
# dotkonnekt — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to `.env` and adjust values for your local setup.
#
# Docker Compose, the Python app, and the Postgres/MinIO/RabbitMQ
# containers all read from this single `.env` file. Variables listed
# below are shared between them where names overlap.
# ─────────────────────────────────────────────

# ── Docker Compose ──────────────────────────
# Service container names
POSTGRES_CONTAINER_NAME=postgres-dtx
QDRANT_CONTAINER_NAME=vectordb-dtx
MINIO_CONTAINER_NAME=minio-dtx
RABBITMQ_CONTAINER_NAME=rabbitmq-dtx

# Qdrant
QDRANT_PORT=6333

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# RabbitMQ management UI
RABBITMQ_MGMT_PORT=15672


# ── Shared (Docker Compose + Python) ────────
# These variables are used by both the Docker service containers
# AND read directly by the Python Settings class.

# PostgreSQL
POSTGRES_USER=dtx_user
POSTGRES_PASSWORD=dtx_password
POSTGRES_DB=dtx_database
POSTGRES_PORT=5432

# RabbitMQ AMQP
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672


# ── App Settings ────────────────────────────
# Read by src/configs/settings.py → Settings
APP_NAME=dotkonnekt
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# Postgres pool
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10

# Qdrant
QDRANT_HOST=localhost
QDRANT_API_KEY=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=ingestion

# Storage (MinIO / S3)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_BUCKET_NAME=dotkonnekt
STORAGE_USE_SSL=false


# ── Docker network hostnames ────────────────
# Uncomment these when the app runs inside the Docker Compose
# network so it can reach services by container name:
# QDRANT_HOST=vectordb
# POSTGRES_HOST=postgres
# RABBITMQ_HOST=rabbitmq
# STORAGE_ENDPOINT_URL=http://minio:9000
